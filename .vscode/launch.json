{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch go-webhook",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": ["serve", "--config", "configs/config.yaml"],
      "env": {
        "GIN_MODE": "debug"
      }
    },
    {
      "name": "Attach to Air",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": "${command:pickProcess}"
    }
  ]
}
